# 苏格拉底之窗 - Environment Configuration

# LLM Configuration (OpenAI-compatible)
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# Embedding Configuration (OpenAI-compatible)
EMBED_API_BASE=https://api.openai.com/v1
EMBED_API_KEY=sk-your-key-here
EMBED_MODEL=text-embedding-3-small
EMBED_DIMENSIONS=1536
# 单次 embedding 请求的最大文本条数（如阿里云 DashScope 上限为 10）
EMBED_BATCH_SIZE=10
# embedding 请求遇到瞬时网络错误时的重试次数
EMBED_MAX_RETRIES=3

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/Socratess_window.db
CHROMA_PERSIST_DIR=./data/chroma

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Document Processing
CHUNK_SIZE=800
CHUNK_OVERLAP=150
MAX_DOCUMENT_SIZE_MB=50
