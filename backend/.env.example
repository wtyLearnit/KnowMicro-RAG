# 苏格拉底之窗 - Environment Configuration
#
# 复制此文件为 .env 并填入你的配置：
#   cp backend/.env.example backend/.env
#
# ⚠️ 重要：LLM/Embedding API Key 也可以通过前端「设置」页面配置，
# 前端配置的 Key 优先级更高，会覆盖此处的默认值。

# ═══════════════════════════════════════════════════
# LLM (问答模型) — 作为兜底默认值，可通过前端覆盖
# ═══════════════════════════════════════════════════
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# ═══════════════════════════════════════════════════
# Embedding (向量化模型) — 作为兜底默认值
# ═══════════════════════════════════════════════════
EMBED_API_BASE=https://api.openai.com/v1
EMBED_API_KEY=sk-your-key-here
EMBED_MODEL=text-embedding-3-small
EMBED_DIMENSIONS=1536
# 单次 embedding 请求的最大文本条数（如阿里云 DashScope 上限为 10）
EMBED_BATCH_SIZE=10
# embedding 请求遇到瞬时网络错误时的重试次数
EMBED_MAX_RETRIES=3

# ═══════════════════════════════════════════════════
# Database (SQLite + ChromaDB)
# ═══════════════════════════════════════════════════
# 默认路径为 backend/data/ 下，一般无需修改
# DATABASE_URL=sqlite+aiosqlite:///path/to/platos_window.db
# CHROMA_PERSIST_DIR=path/to/chroma

# ═══════════════════════════════════════════════════
# Server
# ═══════════════════════════════════════════════════
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ═══════════════════════════════════════════════════
# Security (部署时必须设置！)
# ═══════════════════════════════════════════════════
# SECRET_KEY: 用于加密数据库中存储的 API Key。留空则自动生成并持久化到 data/.secret_key。
#            本地开发可直接留空；生产环境应手动设置为随机字符串。
# SECRET_KEY=your-random-secret-here

# API_TOKEN: API 访问令牌。留空则不校验（仅适合本地开发）。
#           部署到公网时必须设置，前端需在 localStorage 中存入相同值。
# API_TOKEN=your-api-token-here

# ═══════════════════════════════════════════════════
# Document Processing
# ═══════════════════════════════════════════════════
CHUNK_SIZE=800
CHUNK_OVERLAP=150
MAX_DOCUMENT_SIZE_MB=50

# ═══════════════════════════════════════════════════
# Hybrid Search (混合检索)
# ═══════════════════════════════════════════════════
HYBRID_SEARCH_ENABLED=true
BM25_WEIGHT=0.3
SEMANTIC_WEIGHT=0.7

# ═══════════════════════════════════════════════════
# Reranker (重排序)
# ═══════════════════════════════════════════════════
# 首次启动会自动下载模型（约 1.2GB）
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_N=20

# ═══════════════════════════════════════════════════
# Query Rewrite (查询重写)
# ═══════════════════════════════════════════════════
QUERY_REWRITE_ENABLED=true
RETRIEVAL_TOP_K=20

# ═══════════════════════════════════════════════════
# Web Search (网络搜索) — 可选
# ═══════════════════════════════════════════════════
# WEB_SEARCH_BACKEND=duckduckgo
# WEB_SEARCH_MAX_RESULTS=5
# WEB_SEARCH_TIMEOUT=20
# TAVILY_API_KEY=tvly-your-key-here
# BRAVE_API_KEY=your-key-here
# SERPER_API_KEY=your-key-here
