# 苏格拉底之窗 - Environment Configuration

# LLM Configuration (OpenAI-compatible)
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# Embedding Configuration (OpenAI-compatible)
EMBED_API_BASE=https://api.openai.com/v1
EMBED_API_KEY=sk-your-key-here
EMBED_MODEL=text-embedding-3-small
EMBED_DIMENSIONS=1536
# 单次 embedding 请求的最大文本条数（如阿里云 DashScope 上限为 10）
EMBED_BATCH_SIZE=10
# embedding 请求遇到瞬时网络错误时的重试次数
EMBED_MAX_RETRIES=3

# Database — defaults to <backend>/data/platos_window.db (absolute path based on config.py location)
# DATABASE_URL=sqlite+aiosqlite:///path/to/your/platos_window.db
# CHROMA_PERSIST_DIR=path/to/your/chroma

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Document Processing
CHUNK_SIZE=800
CHUNK_OVERLAP=150
MAX_DOCUMENT_SIZE_MB=50

# Hybrid Search (混合检索)
HYBRID_SEARCH_ENABLED=true
BM25_WEIGHT=0.3
SEMANTIC_WEIGHT=0.7

# Reranker (重排序)
RERANKER_ENABLED=true
# 首次启动时会自动下载模型（约 1.2GB），也可使用其他 Cross-Encoder 模型
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_N=20

# Query Rewrite (查询重写)
QUERY_REWRITE_ENABLED=true
RETRIEVAL_TOP_K=20
